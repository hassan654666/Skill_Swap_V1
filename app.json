{
  "expo": {
    "name": "Skill Swap",
    "slug": "skillswap",
    "version": "0.1.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "skillswap",
    "platforms": [
      "ios",
      "android"
    ],
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.example.skillswap",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "skillswap",
              "host": "Home",
              "path": "/%28tabs%29/Home"
            },
            {
              "scheme": "skillswap",
              "host": "LoginPage",
              "path": "/%28tabs%29/LoginPage"
            },
            {
              "scheme": "skillswap",
              "host": "Signup",
              "path": "/%28tabs%29/Signup"
            },
            {
              "scheme": "skillswap",
              "host": "ForgotPassword",
              "path": "/%28tabs%29/ForgotPassword"
            },
            {
              "scheme": "skillswap",
              "host": "ResetPassword",
              "path": "/%28tabs%29/ResetPassword"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "CAMERA",
        "INTERNET",
        "MICROPHONE",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "MANAGE_EXTERNAL_STORAGE",
        "ACCESS_BACKGROUND_LOCATION",
        "NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "3f611978-26cf-4f78-9aea-ffc2ca23d271"
      }
    },
    "owner": "hassan_farooqi"
  }
}
